# .env.example
# 이 파일을 복사하여 .env 파일을 만들고 각 값을 입력하세요.
# cp .env.example .env

# ============================================
# Anthropic Claude API
# ============================================
# https://console.anthropic.com에서 API 키 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# FRED API (경제지표)
# ============================================
# https://fred.stlouisfed.org에서 무료 가입
# API 키: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ============================================
# NewsAPI (뉴스)
# ============================================
# https://newsapi.org에서 무료 플랜 가입
NEWSAPI_KEY=your_newsapi_key_here

# ============================================
# 선택사항: 알림 채널 (향후 구현)
# ============================================
# Telegram Bot
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# KakaoTalk (Flask 서버 필요)
# KAKAO_ACCESS_TOKEN=your_kakao_access_token

# Email
# EMAIL_SENDER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_RECIPIENT=target_email@gmail.com
